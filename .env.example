# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Required ──────────────────────────────────────────────────────────────────

# Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# Steep Analytics API token (Settings → API in Steep)
STEEP_API_TOKEN=your-steep-api-token

# ── Discord bot ───────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token

# Discord channel IDs (right-click channel → Copy Channel ID)
DISCORD_ALERT_CHANNEL_ID=123456789012345678
DISCORD_ERROR_CHANNEL_ID=123456789012345678
DISCORD_STATUS_CHANNEL_ID=123456789012345678

# ── Admin web UI ──────────────────────────────────────────────────────────────

# Random secret for signing session cookies
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-string

# Google OAuth2 credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Only allow sign-in from this Google domain (e.g. yourcompany.com)
# Leave empty to allow any Google account
ALLOWED_DOMAIN=yourcompany.com

# Public URL of the admin web UI (used in Discord /admin command)
ADMIN_URL=https://your-admin-url.run.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Vertex AI region for Gemini (default: us-central1)
# GCP_VERTEXAI_REGION=us-central1

# Gemini model to use (default: gemini-2.0-flash-001)
# GEMINI_MODEL=gemini-2.0-flash-001

# How often the monitor checks metrics in seconds (default: 3600 = 1 hour)
# MONITOR_INTERVAL_SECONDS=3600

# Internal port the bot exposes for config reload signals from the admin UI (default: 8081)
# BOT_INTERNAL_PORT=8081

# URL the admin web UI uses to reach the bot's internal server
# In Cloud Run: set to the bot service's internal URL
# BOT_INTERNAL_URL=http://localhost:8081

# Jira integration for release context in anomaly analysis (all four required to enable)
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=your-email@yourcompany.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=PROJ
