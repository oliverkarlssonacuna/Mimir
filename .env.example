# Google Cloud project that owns the BQ table
GCP_PROJECT_ID=lia-project-sandbox-deletable

# Vertex AI region for Gemini
GCP_VERTEXAI_REGION=us-central1

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash-001

# Discord bot token (needed later, not for dev.py)
DISCORD_BOT_TOKEN=

# Discord channel ID for monitoring alerts (optional)
DISCORD_ALERT_CHANNEL_ID=

# Discord webhook URL for sending alerts (from Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=

# How often the monitor checks BQ in seconds (default 3600 = 1 hour)
MONITOR_INTERVAL_SECONDS=3600

# Dataset where the real source tables live (used for deep analysis)
BQ_SOURCE_DATASET=goals-analytics.prod_event_classes
