# Google Cloud project that owns the BQ table
GCP_PROJECT_ID=lia-project-sandbox-deletable

# Vertex AI region for Gemini
GCP_VERTEXAI_REGION=us-central1

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash-001

# Discord bot token
DISCORD_BOT_TOKEN=

# Discord channel ID for monitoring alerts
DISCORD_ALERT_CHANNEL_ID=

# How often the monitor checks Steep in seconds (default 14400 = 4 hours, matches Steep cache TTL)
MONITOR_INTERVAL_SECONDS=14400

# Jira integration for release context
JIRA_BASE_URL=https://goalsgame.atlassian.net
JIRA_EMAIL=oliver@playgoals.com
JIRA_PROJECT_KEY=GG
JIRA_API_TOKEN=

# Steep API token (Settings → API in Steep)
STEEP_API_TOKEN=

# Admin web UI — URL shown when users run /admin in Discord
ADMIN_URL=http://localhost:8080

# Internal port the bot exposes for config reload signals from the admin UI
BOT_INTERNAL_PORT=8081

# URL the admin web UI uses to reach the bot's internal server
# In Cloud Run: set to the bot service's internal URL, e.g. https://bot-service-xxx.run.internal
BOT_INTERNAL_URL=http://localhost:8081
