FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml .
COPY src/ ./src/

RUN pip install --no-cache-dir \
    "discord.py>=2.0" \
    aiohttp \
    google-cloud-bigquery \
    "google-genai" \
    python-dotenv \
    requests \
    matplotlib

ENV PYTHONPATH=/app/src

CMD ["python3", "src/bot.py"]
